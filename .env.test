# Variáveis de ambiente para testes de integração e E2E
# Requer um banco PostgreSQL rodando localmente

NODE_ENV=test
PORT=3001

# Banco de dados de teste — porta 5435 (docker-compose.test.yml)
# 5432 = postgres compartilhado (dev), 5433 = pgBouncer (outro projeto), 5434 = outro projeto
DB_HOST=localhost
DB_PORT=5435
DB_USER=postgres
DB_PASS=postgres
DB_NAME=sos_casa_test

# JWT — secrets simples para ambiente de teste
JWT_ACCESS_SECRET=test_access_secret_key_32chars_ok
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test_refresh_secret_key_32chars_ok
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173
